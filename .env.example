# Video Source Configuration
VIDEO_SOURCE_MODE=simulation          # webcam | rtsp | video_file | simulation
VIDEO_SOURCE=sample_videos/traffic_sample.mp4
WEBCAM_INDEX=0
RTSP_URL=                             # e.g., rtsp://admin:password@192.168.1.100:554/stream1
RTSP_TIMEOUT=10
TARGET_FPS=15

# YOLO Detection
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4

# Emergency Detection
EMERGENCY_CONFIDENCE=0.5
EMERGENCY_MIN_FRAMES=5
EMERGENCY_CONF_THRESHOLD=0.6

# Density Analysis
DENSITY_THRESHOLD=60
EMA_ALPHA=0.3
STABILITY_WINDOW=3

# Signal Timing
BASE_GREEN_TIME=30
MAX_GREEN_TIME=90
MIN_GREEN_TIME=10
YELLOW_TIME=5
ALL_RED_TIME=2
MAX_CYCLE_TIME=180

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# WebSocket
WS_INTERVAL_MS=500

# Database
DB_WRITE_INTERVAL=5

# System
SIMULATION_MODE=true
LOG_LEVEL=INFO
